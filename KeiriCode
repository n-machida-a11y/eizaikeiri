function transferToKeiriDB_(keiriShoriID, systemType, reportId, details, keiriStatus) {
  var ss = SpreadsheetApp.openById(KEIRI_DB_ID);
  var hSheet = ss.getSheetByName(KEIRI_SHEET_NAMES.HEADERS);
  var dSheet = ss.getSheetByName(KEIRI_SHEET_NAMES.DETAILS);
  ensureDetailColumn_(dSheet, '税区分');

  var h = details.header;
  var expenses = details.expenses;

  var cardTotal = expenses.reduce((sum, ex) => sum + (parseFloat(String(ex['カード利用額']).replace(/,/g,''))||0), 0);
  var totalAmount = parseFloat(String(h['合計金額'] || h['合計経費'] || 0).replace(/,/g,'')) || 0;
  var settleAmount = totalAmount - cardTotal;

  var headerRow = [
    keiriShoriID, systemType, reportId, h['申請日']||new Date(), h['申請者社員番号']||h['申請者ID'], h['担当者']||h['申請者'],
    (systemType === '営業用') ? (h['日付'] + " (" + (h['担当者']||'') + ")") : (h['件名']||h['日付']),
    totalAmount, keiriStatus, null, null, '',
    h['承認者名']||h['承認者']||'', h['精算方法']||'', cardTotal, settleAmount
  ];
  hSheet.appendRow(headerRow);

  var detailRows = expenses.map(function(ex) {
    return [
      keiriShoriID, reportId, ex.expenseId||ex['明細ID']||ex['経費ID'],
      ex.useDate||ex['利用日'], ex.itemCode||ex['経費項目コード'], ex.itemName,
      ex.amount||ex['金額'], ex['税抜金額']||null, ex['消費税']||null,
      ex['カード利用額']||0,
      ex.areaCode||ex['エリアコード']||null, ex.remarks||ex['備考'], ex.receiptUrl||ex['領収書URL'],
      ex.accountTitle||'',
      ex['消費税率']||'',
      ex['税区分']||''
    ];
  });
  if (detailRows.length > 0) dSheet.getRange(dSheet.getLastRow()+1, 1, detailRows.length, detailRows[0].length).setValues(detailRows);
}

function updateKeiriDB_OnResubmit_(keiriShoriID, systemType, reportId, details, newStatus) {
    var ss = SpreadsheetApp.openById(KEIRI_DB_ID);
    var hSheet = ss.getSheetByName(KEIRI_SHEET_NAMES.HEADERS);
    var dSheet = ss.getSheetByName(KEIRI_SHEET_NAMES.DETAILS);
    ensureDetailColumn_(dSheet, '税区分');

    var hData = hSheet.getDataRange().getValues();
    var hIdxId = hData[0].indexOf('経理処理ID');

    var h = details.header;
    var expenses = details.expenses;
    var cardTotal = expenses.reduce((sum, ex) => sum + (parseFloat(String(ex['カード利用額']).replace(/,/g,''))||0), 0);
    var totalAmount = parseFloat(String(h['合計金額'] || h['合計経費'] || 0).replace(/,/g,'')) || 0;
    var settleAmount = totalAmount - cardTotal;

    for (var i=1; i<hData.length; i++) {
        if (hData[i][hIdxId] === keiriShoriID) {
            var row = i+1;
            var hHeaders = hData[0];
            hSheet.getRange(row, hHeaders.indexOf('経理ステータス')+1).setValue(newStatus);
            hSheet.getRange(row, hHeaders.indexOf('合計金額')+1).setValue(totalAmount);
            var idxCard = hHeaders.indexOf('カード利用額');
            var idxSettle = hHeaders.indexOf('精算金額');
            if(idxCard > -1) hSheet.getRange(row, idxCard+1).setValue(cardTotal);
            if(idxSettle > -1) hSheet.getRange(row, idxSettle+1).setValue(settleAmount);
            break;
        }
    }

    var dData = dSheet.getDataRange().getValues();
    var dIdxId = dData[0].indexOf('経理処理ID');
    var rowsToDelete = [];
    for(var i=1; i<dData.length; i++) { if(dData[i][dIdxId] === keiriShoriID) rowsToDelete.push(i+1); }
    rowsToDelete.sort((a,b)=>b-a).forEach(r => dSheet.deleteRow(r));

    var detailRows = expenses.map(function(ex) {
        return [
            keiriShoriID, reportId, ex.expenseId||ex['明細ID']||ex['経費ID'],
            ex.useDate||ex['利用日'], ex.itemCode||ex['経費項目コード'], ex.itemName,
            ex.amount||ex['金額'], ex['税抜金額']||null, ex['消費税']||null,
            ex['カード利用額']||0,
            ex.areaCode||ex['エリアコード']||null, ex.remarks||ex['備考'], ex.receiptUrl||ex['領収書URL'],
            ex.accountTitle||'',
            ex['消費税率']||'',
            ex['税区分']||''
        ];
    });
    if(detailRows.length > 0) dSheet.getRange(dSheet.getLastRow()+1, 1, detailRows.length, detailRows[0].length).setValues(detailRows);
}

