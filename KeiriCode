function getReportDetailsForKeiri(keiriShoriID) {
  checkAccess_();
  try {
    var ss = SpreadsheetApp.openById(KEIRI_DB_ID);

    // ヘッダーから申請者IDを取得
    var hSheet = ss.getSheetByName(KEIRI_SHEET_NAMES.HEADERS);
    var hData = getSheetData_(hSheet);
    var header = hData.find(r => String(r['経理処理ID']) === String(keiriShoriID));
    var applicantId = header ? (header['申請者社員番号'] || header['申請者ID']) : null;

    // 明細取得
    var dSheet = ss.getSheetByName(KEIRI_SHEET_NAMES.DETAILS);
    var detailData = getSheetData_(dSheet);
    var filteredDetails = detailData.filter(function(row) { return String(row['経理処理ID']) === String(keiriShoriID); });

    var employeeMap = getEmployeeJobTypeMap_();
    var titleMap = getAccountTitleDefinitions_();
    var jobType = applicantId ? employeeMap[applicantId] : null;

    filteredDetails = filteredDetails.map(function(d) {
      // 科目解決
      var code = d['経費項目コード'];
      var key = String(code) + '_' + String(jobType);
      var masterAccountTitle = titleMap[key] || '';
      d.accountTitle = d['勘定科目'] || masterAccountTitle;

      d.taxRate = d['消費税率'] || '';
      d.taxCategory = d['税区分'] || d['消費税率'] || '';
      d.itemName = d['経費項目名'] || '';

      // 数値補正
      var rawAmount = String(d['金額']).replace(/,/g, '');
      var rawCard = String(d['カード利用額'] || d['カード'] || '0').replace(/,/g, '');

      d.amount = parseFloat(rawAmount) || 0;
      d.cardAmount = parseFloat(rawCard) || 0;
      d.settlementAmount = d.amount - d.cardAmount;

      return d;
    });
    return { status: "success", details: filteredDetails };
  } catch (e) { return { status: "error", message: e.message }; }
}

function getExpenseMasterList() {
  checkAccess_();
  try {
    var ss = SpreadsheetApp.openById(GENERAL_MASTER_DB_ID);
    var sheet = ss.getSheetByName(MASTER_SHEET_NAMES.EXPENSE_DEFINITION);
    var data = getSheetData_(sheet);
    var seen = {};
    var list = [];
    data.forEach(function(row) {
      var code = row['経費項目コード'];
      var name = row['経費項目'];
      if (code && name && !seen[code]) {
        seen[code] = true;
        list.push({ code: code, name: name });
      }
    });
    return { status: "success", list: list };
  } catch (e) { return { status: "error", message: e.message }; }
}

