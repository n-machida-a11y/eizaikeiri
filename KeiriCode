function syncDataFromSources() {
  var userInfo = checkAccess_();
  var totalNew = 0;
  var keiriHeaders = loadPendingHeaders_Internal_();
  var keiriIdMap = {};
  keiriHeaders.forEach(function(h) { keiriIdMap[h['元申請ID']] = h; });

  try { totalNew += syncFromSalesDB_(keiriIdMap); } catch (e) { Logger.log('Sales Sync Error: ' + e); }
  try { totalNew += syncFromGeneralDB_(keiriIdMap); } catch (e) { Logger.log('General Sync Error: ' + e); }

  return { status: "success", message: "同期完了: " + totalNew + "件", totalNew: totalNew };
}

function syncFromSalesDB_(keiriIdMap) { return syncDB_(SALES_DB_ID, SALES_SHEET_NAMES, keiriIdMap, '営業用', '日報ID'); }
function syncFromGeneralDB_(keiriIdMap) { return syncDB_(GENERAL_DATA_DB_ID, GENERAL_SHEET_NAMES, keiriIdMap, '一般用', '経費ID'); }

function syncDB_(dbId, names, keiriIdMap, sysType, idColName) {
  var ss = SpreadsheetApp.openById(dbId);
  var headerSheet = ss.getSheetByName(names.HEADER || names.REPORTS);
  if (!headerSheet) return 0;

  var range = headerSheet.getRange(1, 1, headerSheet.getLastRow(), headerSheet.getLastColumn());
  var allValues = range.getValues();
  var headers = allValues[0];
  var idxStatus = headers.indexOf('承認ステータス');
  var idxFinal = headers.indexOf('最終ステータス');
  var idxId = headers.indexOf(idColName);
  var idxEmpId = headers.indexOf('申請者社員番号') > -1 ? headers.indexOf('申請者社員番号') : headers.indexOf('申請者ID');

  var employeeMap = getEmployeeJobTypeMap_();
  var titleMap = getAccountTitleDefinitions_();

  if (idxStatus === -1) return 0;
  var newCount = 0;
  for (var i = 1; i < allValues.length; i++) {
    var row = allValues[i];
    if (row[idxStatus] === '精算申請済' || row[idxStatus] === '承認済') {
      var reportId = row[idxId];
      var applicantId = idxEmpId > -1 ? row[idxEmpId] : null;

      var existing = keiriIdMap[reportId];
      if (!existing || existing['経理ステータス'] === '経理差戻し') {
          var details = getReportDetails_(reportId, ss, names, idColName);

          var jobType = applicantId ? employeeMap[applicantId] : null;
          details.expenses.forEach(function(ex) {
             var key = String(ex['経費項目コード']) + '_' + String(jobType);
             ex.accountTitle = titleMap[key] || '';
          });

          var kId = existing ? existing['経理処理ID'] : 'PAY-' + Utilities.getUuid();
          if (existing) updateKeiriDB_OnResubmit_(kId, sysType, reportId, details, '振込待ち');
          else transferToKeiriDB_(kId, sysType, reportId, details, '振込待ち');

          if (idxFinal > -1) headerSheet.getRange(i+1, idxFinal + 1).setValue('経理転記済');
          newCount++;
      }
    }
  }
  return newCount;
}

