function updateDetailItems(keiriId, updatesList, systemType, originalReportId) {
  var userInfo = checkAccess_();
  var lock = LockService.getScriptLock();
  if (!lock.tryLock(15000)) return { status: "error", message: "他ユーザーが処理中です。" };

  try {
    var keiriSs = SpreadsheetApp.openById(KEIRI_DB_ID);
    var keiriDetailSheet = keiriSs.getSheetByName(KEIRI_SHEET_NAMES.DETAILS);
    var keiriHeaderSheet = keiriSs.getSheetByName(KEIRI_SHEET_NAMES.HEADERS);

    var hDataRaw = keiriHeaderSheet.getDataRange().getValues();
    var hHeadersTmp = hDataRaw[0];
    var hRow = hDataRaw.find(r => String(r[hHeadersTmp.indexOf('経理処理ID')]) === String(keiriId));
    var applicantId = hRow ? (hRow[hHeadersTmp.indexOf('申請者社員番号')] || hRow[hHeadersTmp.indexOf('申請者ID')]) : null;

    var employeeMap = getEmployeeJobTypeMap_();
    var titleMap = getAccountTitleDefinitions_();
    var jobType = applicantId ? employeeMap[applicantId] : null;

    var detailData = keiriDetailSheet.getDataRange().getValues();
    var dHeaders = detailData[0];
    var idxKeiriId = dHeaders.indexOf('経理処理ID');
    var idxDetailId = dHeaders.indexOf('明細ID');
    var idxAmount = dHeaders.indexOf('金額');
    var idxCard = dHeaders.indexOf('カード利用額');
    var idxItemCode = dHeaders.indexOf('経費項目コード');
    var idxItemName = dHeaders.indexOf('経費項目名');
    var idxRemarks = dHeaders.indexOf('備考');
    var idxAccount = dHeaders.indexOf('勘定科目');
    var idxTaxCategory = dHeaders.indexOf('税区分');

    var sourceSsId = (systemType === '営業用') ? SALES_DB_ID : GENERAL_DATA_DB_ID;
    var sourceSheetName = (systemType === '営業用') ? SALES_SHEET_NAMES.EXPENSES : GENERAL_SHEET_NAMES.EXPENSES;
    var sourceSs = SpreadsheetApp.openById(sourceSsId);
    var sourceSheet = sourceSs.getSheetByName(sourceSheetName);
    var sData = sourceSheet.getDataRange().getValues();
    var sHeaders = sData[0];
    var sIdxDetailId = sHeaders.indexOf('明細ID'); if(sIdxDetailId<0) sIdxDetailId=sHeaders.indexOf('経費明細ID'); if(sIdxDetailId<0) sIdxDetailId=sHeaders.indexOf('経費ID');
    var sIdxAmount = sHeaders.indexOf('金額');
    var sIdxCard = sHeaders.indexOf('カード利用額');
    var sIdxCode = sHeaders.indexOf('経費項目コード');
    var sIdxRemarks = sHeaders.indexOf('備考');
    var sIdxTaxCategory = sHeaders.indexOf('税区分');
    var sIdxTaxRate = sHeaders.indexOf('消費税率');

    updatesList.forEach(function(updates) {
      var detailId = updates.detailId;

      // 勘定科目: 手動入力がなければ経費項目コードから自動計算
      if (updates.itemCode && !updates.accountTitle) {
          var key = String(updates.itemCode) + '_' + String(jobType);
          updates.accountTitle = titleMap[key] || '';
      }

      for (var i = 1; i < detailData.length; i++) {
        if (String(detailData[i][idxKeiriId]) === String(keiriId) && String(detailData[i][idxDetailId]) === String(detailId)) {
          var row = i + 1;
          if (idxAmount > -1) keiriDetailSheet.getRange(row, idxAmount + 1).setValue(updates.amount);
          if (idxCard > -1) keiriDetailSheet.getRange(row, idxCard + 1).setValue(updates.cardAmount);
          if (idxItemCode > -1) keiriDetailSheet.getRange(row, idxItemCode + 1).setValue(updates.itemCode);
          if (idxItemName > -1) keiriDetailSheet.getRange(row, idxItemName + 1).setValue(updates.itemName);
          if (idxRemarks > -1) keiriDetailSheet.getRange(row, idxRemarks + 1).setValue(updates.remarks);
          if (idxAccount > -1) keiriDetailSheet.getRange(row, idxAccount + 1).setValue(updates.accountTitle);
          if (idxTaxCategory > -1 && updates.taxCategory !== undefined) keiriDetailSheet.getRange(row, idxTaxCategory + 1).setValue(updates.taxCategory);
          break;
        }
      }

      if (sIdxDetailId > -1) {
        for (var k = 1; k < sData.length; k++) {
          if (String(sData[k][sIdxDetailId]) === String(detailId)) {
            var sRow = k + 1;
            if (sIdxAmount > -1) sourceSheet.getRange(sRow, sIdxAmount + 1).setValue(updates.amount);
            if (sIdxCard > -1) sourceSheet.getRange(sRow, sIdxCard + 1).setValue(updates.cardAmount);
            if (sIdxCode > -1) sourceSheet.getRange(sRow, sIdxCode + 1).setValue(updates.itemCode);
            if (sIdxRemarks > -1) sourceSheet.getRange(sRow, sIdxRemarks + 1).setValue(updates.remarks);
            var sTaxColIdx = sIdxTaxCategory > -1 ? sIdxTaxCategory : sIdxTaxRate;
            if (sTaxColIdx > -1 && updates.taxCategory !== undefined) sourceSheet.getRange(sRow, sTaxColIdx + 1).setValue(updates.taxCategory);
            break;
          }
        }
      }
    });

    var currentDetails = getSheetData_(keiriDetailSheet);
    var targetDetails = currentDetails.filter(d => String(d['経理処理ID']) === String(keiriId));

    var newTotal = targetDetails.reduce((sum, d) => sum + (parseFloat(String(d['金額']).replace(/,/g,'')) || 0), 0);
    var newCardTotal = targetDetails.reduce((sum, d) => sum + (parseFloat(String(d['カード利用額']).replace(/,/g,'')) || 0), 0);
    var newSettlement = newTotal - newCardTotal;

    var hIdxId = hHeadersTmp.indexOf('経理処理ID');
    for (var j = 1; j < hDataRaw.length; j++) {
      if (String(hDataRaw[j][hIdxId]) === String(keiriId)) {
        var rowNum = j + 1;
        var hIdxTotal = hHeadersTmp.indexOf('合計金額');
        var hIdxCard = hHeadersTmp.indexOf('カード利用額');
        var hIdxSettle = hHeadersTmp.indexOf('精算金額');

        if (hIdxTotal > -1) keiriHeaderSheet.getRange(rowNum, hIdxTotal + 1).setValue(newTotal);
        if (hIdxCard > -1) keiriHeaderSheet.getRange(rowNum, hIdxCard + 1).setValue(newCardTotal);
        if (hIdxSettle > -1) keiriHeaderSheet.getRange(rowNum, hIdxSettle + 1).setValue(newSettlement);
        break;
      }
    }

    return { status: "success", message: "更新完了しました。", newTotal: newSettlement };
  } catch (e) { return { status: "error", message: e.message }; }
  finally { lock.releaseLock(); }
}

