function getEmployeeJobTypeMap_() {
  var ss = SpreadsheetApp.openById(GENERAL_MASTER_DB_ID);
  var sheet = ss.getSheetByName(MASTER_SHEET_NAMES.EMPLOYEES);
  var data = getSheetData_(sheet);
  var map = {};
  data.forEach(function(row) {
    if (row['社員番号']) {
      map[row['社員番号']] = row['職種区分'];
    }
  });
  return map;
}

function getAccountTitleDefinitions_() {
  var ss = SpreadsheetApp.openById(GENERAL_MASTER_DB_ID);
  var sheet = ss.getSheetByName(MASTER_SHEET_NAMES.EXPENSE_DEFINITION);
  var data = getSheetData_(sheet);
  var map = {};
  data.forEach(function(row) {
    var code = row['経費項目コード'];
    var jobType = row['職種区分'];
    if (code) {
      var key = String(code) + '_' + String(jobType);
      map[key] = row['借方科目名'];
    }
  });
  return map;
}

// --- その他ヘルパー ---

/**
 * 修正: 承認者の結合ロジックを追加
 */
function getReportDetails_(reportId, ss, names, idColName) {
  var hData = getSheetData_(ss.getSheetByName(names.HEADER||names.REPORTS));
  var header = hData.find(r => String(r[idColName]) === String(reportId));
  var dData = getSheetData_(ss.getSheetByName(names.EXPENSES));
  var expenses = dData.filter(r => String(r[idColName]) === String(reportId));

  if(header) {
      header['申請者'] = header['申請者'] || header['申請者名'];
      header['合計金額'] = header['合計金額'] || header['合計経費'];

      // ★ 承認者名を結合するロジック (列名の揺れに対応)
      var app1 = header['承認者名1'] || header['承認者1'] || '';
      var app2 = header['承認者名2'] || header['承認者2'] || '';

      var approverList = [];
      if (app1) approverList.push(app1);
      if (app2) approverList.push(app2);

      // 結合した文字列をセット（transferToKeiriDB_ で保存される）
      header['承認者名'] = approverList.length > 0 ? approverList.join(' / ') : '';
  }
  return { header: header||{}, expenses: expenses };
}

function ensureDetailColumn_(sheet, colName) {
  var lastCol = sheet.getLastColumn();
  var headers = lastCol > 0 ? sheet.getRange(1, 1, 1, lastCol).getValues()[0] : [];
  if (headers.indexOf(colName) === -1) {
    sheet.getRange(1, lastCol + 1).setValue(colName);
  }
}

function getSheetData_(sheet) {
  if (!sheet || sheet.getLastRow() < 2) return [];
  var data = sheet.getRange(1, 1, sheet.getLastRow(), sheet.getLastColumn()).getValues();
  var headers = data.shift();
  return data.map(row => {
    var obj = {};
    headers.forEach((h, i) => { obj[h] = (row[i] instanceof Date) ? Utilities.formatDate(row[i], Session.getScriptTimeZone(), 'yyyy/MM/dd') : row[i]; });
    return obj;
  });
}

function loadPendingHeaders_Internal_() {
  var ss = SpreadsheetApp.openById(KEIRI_DB_ID);
  var sheet = ss.getSheetByName(KEIRI_SHEET_NAMES.HEADERS);
  return sheet ? getSheetData_(sheet) : [];
}

function loadPendingHeaders() {
  checkAccess_();
  try { var data = loadPendingHeaders_Internal_(); return { status: "success", data: data.filter(r => r['経理ステータス'] === '振込待ち') }; } catch (e) { return { status: "error", message: e.message }; }
}

function markAsProcessed(ids, name) { return processStatusChange_(ids, name, '振込済'); }
function processStatusChange_(ids, name, status) {
    var userInfo = checkAccess_();
    var targetIds = Array.isArray(ids) ? ids : [ids];
    var ss = SpreadsheetApp.openById(KEIRI_DB_ID);
    var sheet = ss.getSheetByName(KEIRI_SHEET_NAMES.HEADERS);
    var data = sheet.getDataRange().getValues();
    var h = data[0];
    var idxId = h.indexOf('経理処理ID'), idxStat = h.indexOf('経理ステータス'), idxDate = h.indexOf('処理日'), idxPerson = h.indexOf('担当経理');
    var count = 0, today = new Date();
    for (var i=1; i<data.length; i++) {
        if (targetIds.indexOf(data[i][idxId]) > -1) {
            if (idxStat > -1) sheet.getRange(i+1, idxStat+1).setValue(status);
            if (idxDate > -1) sheet.getRange(i+1, idxDate+1).setValue(today);
            if (idxPerson > -1) sheet.getRange(i+1, idxPerson+1).setValue(userInfo.name);
            count++;
        }
    }
    return { status: "success", message: count + "件処理しました。" };
}

function markAsRejected(id, reason) {
    var userInfo = checkAccess_();
    var lock = LockService.getScriptLock(); lock.waitLock(10000);
    try {
        var ss = SpreadsheetApp.openById(KEIRI_DB_ID);
        var sheet = ss.getSheetByName(KEIRI_SHEET_NAMES.HEADERS);
        var data = sheet.getDataRange().getValues();
        var h = data[0];
        var idxId = h.indexOf('経理処理ID'), idxStat = h.indexOf('経理ステータス'), idxOrig = h.indexOf('元申請ID'), idxSys = h.indexOf('システム区分');
        var targetRow=-1, origId, sys;
        for(var i=1; i<data.length; i++) { if(data[i][idxId]===id) { targetRow=i+1; origId=data[i][idxOrig]; sys=data[i][idxSys]; break; } }
        if(targetRow<0) throw new Error("IDなし");

        sheet.getRange(targetRow, idxStat+1).setValue('経理差戻し');

        var srcId = (sys==='営業用')?SALES_DB_ID:GENERAL_DATA_DB_ID;
        var srcName = (sys==='営業用')?SALES_SHEET_NAMES.HEADER:GENERAL_SHEET_NAMES.REPORTS;
        var srcSs = SpreadsheetApp.openById(srcId);
        var srcSheet = srcSs.getSheetByName(srcName);
        var sData = srcSheet.getDataRange().getValues();
        var sh = sData[0];
        var sIdxId = sh.indexOf((sys==='営業用')?'日報ID':'経費ID'), sIdxStat = sh.indexOf('承認ステータス'), sIdxCom = sh.indexOf('経理コメント'), sIdxFin = sh.indexOf('最終ステータス');
        for(var k=1; k<sData.length; k++) {
            if(String(sData[k][sIdxId])===String(origId)) {
                srcSheet.getRange(k+1, sIdxStat+1).setValue('差戻し');
                if(sIdxFin>-1) srcSheet.getRange(k+1, sIdxFin+1).clearContent();
                if(sIdxCom>-1) srcSheet.getRange(k+1, sIdxCom+1).setValue('経理(' + userInfo.name + '): ' + reason);
                break;
            }
        }
        return { status: "success", message: "差戻しました" };
    } catch(e) { return { status: "error", message: e.message }; } finally { lock.releaseLock(); }
}

// selectedIds: 指定があればその経理処理IDのみ出力、null/空なら全件
function exportPendingAsCSV(selectedIds) {
    checkAccess_();
    try {
        var allHeaders = loadPendingHeaders_Internal_().filter(h => h['経理ステータス'] === '振込待ち');
        var headers = (selectedIds && selectedIds.length > 0)
            ? allHeaders.filter(h => selectedIds.indexOf(h['経理処理ID']) > -1)
            : allHeaders;

        var ss = SpreadsheetApp.openById(KEIRI_DB_ID);
        var detailSheet = ss.getSheetByName(KEIRI_SHEET_NAMES.DETAILS);
        var detailData = getSheetData_(detailSheet);

        var csvRows = [];
        var csvHeader = ["システム","申請日","申請者","合計金額","精算金額","カード合計","経理ID","利用日","経費項目","勘定科目","税区分","金額","カード利用","備考"];
        csvRows.push(csvHeader.join(','));

        headers.forEach(h => {
            var details = detailData.filter(d => d['経理処理ID'] === h['経理処理ID']);
            details.forEach(d => {
                var row = [
                    h['システム区分'], h['申請日'], h['申請者名'], h['合計金額'], h['精算金額']||'', h['カード利用額']||'',
                    h['経理処理ID'], d['利用日'], d['経費項目名'], d['勘定科目']||'', d['税区分']||d['消費税率']||'', d['金額'], d['カード利用額']||'', d['備考']
                ];
                csvRows.push(row.map(v => '"' + String(v).replace(/"/g, '""') + '"').join(','));
            });
        });
        var fn = 'keiri_' + Utilities.formatDate(new Date(), Session.getScriptTimeZone(), 'MMdd') + '.csv';
        // BOM付きUTF-8でExcelの文字化けを防止
        return { status: "success", csvData: '\uFEFF' + csvRows.join('\n'), fileName: fn };
    } catch(e) { return { status: "error", message: e.message }; }
}
