    <!-- モーダル: 確認ダイアログ（alert/confirm代替） -->
    <div class="modal fade" id="confirmModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content border-0 shadow">
                <div class="modal-body py-4 px-4 text-center">
                    <p id="confirmMessage" class="mb-0"></p>
                </div>
                <div class="modal-footer border-0 justify-content-center pb-3 gap-2">
                    <button class="btn btn-light px-4" id="confirmCancelBtn">キャンセル</button>
                    <button class="btn btn-primary px-4" id="confirmOkBtn">OK</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        var USER_NAME = '<?= userName ?>';
        var pendingData = [];
        var expenseMasterList = [];
        var currentKeiriId = null;
        var currentHeader = null;
        var isEditMode = false;
        var currentStatus = '振込待ち';

        var detailModal, rejectModal, confirmModal, appToast;
        var confirmCallback = null;

        document.addEventListener('DOMContentLoaded', function() {
            document.getElementById('user-info-display').textContent = USER_NAME + ' (' + (<?= isAccountant ?> ? '経理' : '閲覧者') + ')';
            detailModal = new bootstrap.Modal(document.getElementById('reportDetailModal'));
            rejectModal = new bootstrap.Modal(document.getElementById('rejectModal'));
            confirmModal = new bootstrap.Modal(document.getElementById('confirmModal'));
            appToast = new bootstrap.Toast(document.getElementById('appToast'), { delay: 3000 });

            loadExpenseMaster();

            document.getElementById('editModeSwitch').addEventListener('change', e => toggleEditMode(e.target.checked));
            document.getElementById('check-all').addEventListener('change', e => toggleAll(e.target.checked));
            document.getElementById('detailProcessBtn').addEventListener('click', () => handleProcess(currentKeiriId));
            document.getElementById('detailRejectBtn').addEventListener('click', () => openRejectModal(currentKeiriId));
            document.getElementById('confirmRejectBtn').addEventListener('click', confirmReject);
            document.getElementById('confirmOkBtn').addEventListener('click', function() {
                confirmModal.hide();
                if (confirmCallback) { confirmCallback(); confirmCallback = null; }
            });
            document.getElementById('confirmCancelBtn').addEventListener('click', function() {
                confirmModal.hide();
                confirmCallback = null;
            });

            loadPendingData();
        });

        // --- 通知ヘルパー ---
        function showToast(message, isError) {
            var el = document.getElementById('appToast');
            el.className = 'toast align-items-center border-0 text-white ' + (isError ? 'bg-danger' : 'bg-success');
            document.getElementById('toastMessage').textContent = message;
            appToast.show();
        }

        function showConfirm(message, okLabel, callback) {
            document.getElementById('confirmMessage').textContent = message;
            document.getElementById('confirmOkBtn').textContent = okLabel || 'OK';
            confirmCallback = callback;
            confirmModal.show();
        }

        // --- データロード ---
        function loadExpenseMaster() {
            google.script.run.withSuccessHandler(res => { if(res.status==='success') expenseMasterList = res.list; }).getExpenseMasterList();
        }

        function switchTab(status) {
            currentStatus = status;
            document.getElementById('tab-pending').classList.toggle('active', status === '振込待ち');
            document.getElementById('tab-processed').classList.toggle('active', status === '振込済');
            document.getElementById('action-footer').style.display = status === '振込待ち' ? '' : 'none';
            document.getElementById('check-all').checked = false;
            loadPendingData();
        }

        function loadPendingData() {
            showLoading(true);
            google.script.run
                .withSuccessHandler(onLoadPendingDataSuccess)
                .withFailureHandler(e => { showLoading(false); showToast('読み込みエラー: ' + e.message, true); })
                .loadPendingHeaders(currentStatus);
        }

        function onLoadPendingDataSuccess(result) {
            showLoading(false);
            if (result.status === 'error') { showToast(result.message, true); return; }
            pendingData = result.data || [];
            renderPendingList();
        }

        // 一覧を描画（金額0円を除外）
        function renderPendingList() {
            var filtered = pendingData.filter(row => parseCurrency(row['合計金額']) > 0);
            var tbody = document.getElementById('pending-list-body');
            tbody.innerHTML = '';

            var count = filtered.length;
            var emptyLabel = currentStatus === '振込待ち' ? '支払待ち' : '支払済';
            if (count === 0) {
                tbody.innerHTML = '<tr><td colspan="7" class="text-center p-5 text-muted">現在、' + emptyLabel + 'の申請はありません。</td></tr>';
            } else {
                filtered.forEach(function(row) {
                    var tr = document.createElement('tr');
                    tr.onclick = (e) => { if(e.target.type !== 'checkbox' && e.target.tagName !== 'BUTTON') openDetailModal(row['経理処理ID']); };
                    var safeId = escapeHtml(row['経理処理ID']);
                    tr.innerHTML = `
                        <td class="text-center" onclick="event.stopPropagation()">
                            <input class="form-check-input pending-checkbox" type="checkbox" value="${safeId}">
                        </td>
                        <td>${formatDate(row['申請日'])}</td>
                        <td><span class="badge bg-secondary system-badge">${escapeHtml(row['システム区分'])}</span></td>
                        <td class="fw-medium">${escapeHtml(row['申請者名'])}</td>
                        <td><div class="text-truncate" style="max-width: 300px;">${escapeHtml(row['件名'])}</div></td>
                        <td class="text-end fw-bold amount-display">${formatNumber(row['合計金額'])}</td>
                        <td class="text-center">
                            <button class="btn btn-sm btn-outline-secondary rounded-pill px-3" onclick="event.stopPropagation(); openDetailModal('${safeId}')">詳細</button>
                        </td>
                    `;
                    tbody.appendChild(tr);
                });
            }
            document.getElementById('pending-count').textContent = count + ' 件';
            var badgeId = currentStatus === '振込待ち' ? 'badge-pending' : 'badge-processed';
            document.getElementById(badgeId).textContent = count;
        }

        // 処理済みIDをローカルデータから除去して再描画（サーバー再取得なし）
        function removeItemsFromList(ids) {
            var idArray = Array.isArray(ids) ? ids : [ids];
            pendingData = pendingData.filter(d => idArray.indexOf(d['経理処理ID']) === -1);
            renderPendingList();
        }

        // --- 詳細・編集 ---
        function openDetailModal(keiriId) {
            currentKeiriId = keiriId;
            currentHeader = pendingData.find(d => d['経理処理ID'] === keiriId);
            if (!currentHeader) return;

            document.getElementById('editModeSwitch').checked = false;
            isEditMode = false;
            document.getElementById('saveChangesBtn').classList.add('d-none');

            document.getElementById('detailKeiriId').textContent = currentHeader['経理処理ID'];
            document.getElementById('detailSystemType').textContent = currentHeader['システム区分'];
            document.getElementById('detailApplicant').textContent = currentHeader['申請者名'];
            document.getElementById('detailApplyDate').textContent = formatDate(currentHeader['申請日']);
            document.getElementById('detailSubject').textContent = currentHeader['件名'];
            document.getElementById('detailApprover').textContent = currentHeader['承認者名'] || currentHeader['承認者'] || '-';
            document.getElementById('detailTotalAmount').textContent = formatNumber(currentHeader['合計金額']);
            document.getElementById('detailCardTotal').textContent = formatNumber(currentHeader['カード利用額'] || 0);
            document.getElementById('detailSettlementAmount').textContent = formatNumber(currentHeader['精算金額'] || currentHeader['合計金額']);

            // モーダルを先に表示し、明細はローディング表示で読み込む
            document.getElementById('reportDetailsBody').innerHTML =
                '<tr><td colspan="9" class="text-center py-4 text-muted"><div class="spinner-border spinner-border-sm me-2"></div>明細読み込み中...</td></tr>';
            detailModal.show();

            google.script.run.withSuccessHandler(function(res) {
                if (res.status === 'success') {
                    renderDetails(res.details);
                    updateHeaderAmountsFromDetails(res.details);
                } else {
                    showToast(res.message, true);
                }
            }).getReportDetailsForKeiri(keiriId);
        }

        function renderDetails(details) {
            var tbody = document.getElementById('reportDetailsBody');
            tbody.innerHTML = '';

            details.forEach(detail => {
                var tr = document.createElement('tr');
                tr.dataset.detailId = detail['明細ID'];

                // 領収書: data-url属性でURLを保持し、行追加後にリスナーを付与
                var receiptUrl = detail['領収書URL'] || '';
                var receipt = receiptUrl
                    ? `<a href="#" class="text-primary receipt-link" data-url="${escapeHtml(receiptUrl)}"><i class="bi bi-image"></i></a>`
                    : '<span class="text-muted">-</span>';

                var amountVal = (detail.amount !== undefined) ? detail.amount : parseCurrency(detail['金額']);
                var cardVal = (detail.cardAmount !== undefined) ? detail.cardAmount : parseCurrency(detail['カード利用額']);
                var settleVal = (detail.settlementAmount !== undefined) ? detail.settlementAmount : (amountVal - cardVal);

                var cardText = cardVal > 0 ? `<span class="text-danger">${formatNumber(cardVal)}</span>` : '<span class="text-muted">-</span>';
                var settleText = settleVal !== 0 ? formatNumber(settleVal) : '<span class="text-muted">0</span>';

                var accountTitleVal = detail.accountTitle || detail['勘定科目'] || '';
                var taxCategoryVal = detail.taxCategory || detail['消費税率'] || '';

                tr.innerHTML = `
                    <td>${formatDate(detail['利用日'])}</td>
                    <td class="cell-item" data-val="${escapeHtml(detail['経費項目コード'])}">${escapeHtml(detail['経費項目名'])}</td>
                    <td class="cell-account small text-muted" data-val="${escapeHtml(accountTitleVal)}">${escapeHtml(accountTitleVal) || '-'}</td>
                    <td class="cell-amount text-end fw-bold amount-display" data-val="${amountVal}">${formatNumber(amountVal)}</td>
                    <td class="cell-card text-end" data-val="${cardVal}">${cardText}</td>
                    <td class="text-end fw-bold text-primary amount-display" style="background-color: #f0f8ff;">${settleText}</td>
                    <td class="cell-tax text-center small" data-val="${escapeHtml(taxCategoryVal)}">${escapeHtml(taxCategoryVal) || '-'}</td>
                    <td class="cell-remarks text-break-word small" data-val="${escapeHtml(detail['備考'])}">${escapeHtml(detail['備考'])}</td>
                    <td class="text-center">${receipt}</td>
                `;
                tbody.appendChild(tr);
                // 領収書リンクにイベントリスナーを付与（URLをHTML属性に含めない）
                tr.querySelectorAll('.receipt-link').forEach(function(link) {
                    link.addEventListener('click', function(e) {
                        e.preventDefault();
                        window.open(this.dataset.url, 'receipt', 'width=900,height=700,scrollbars=yes,resizable=yes');
                    });
                });
            });
        }

        function updateHeaderAmountsFromDetails(details) {
            var totalAmount = 0, totalCard = 0;
            details.forEach(function(d) {
                totalAmount += (d.amount !== undefined) ? d.amount : parseCurrency(d['金額']);
                totalCard += (d.cardAmount !== undefined) ? d.cardAmount : parseCurrency(d['カード利用額']);
            });
            document.getElementById('detailTotalAmount').textContent = formatNumber(totalAmount);
            document.getElementById('detailCardTotal').textContent = formatNumber(totalCard);
            document.getElementById('detailSettlementAmount').textContent = formatNumber(totalAmount - totalCard);
        }

        function parseCurrency(val) {
            if (!val) return 0;
            if (typeof val === 'number') return val;
            return parseFloat(val.toString().replace(/,/g, '')) || 0;
        }

        function toggleEditMode(enabled) {
            isEditMode = enabled;
            document.getElementById('saveChangesBtn').classList.toggle('d-none', !enabled);

            var rows = document.querySelectorAll('#reportDetailsBody tr');
            rows.forEach(row => {
                var cellAmount = row.querySelector('.cell-amount');
                var cellCard = row.querySelector('.cell-card');
                var cellItem = row.querySelector('.cell-item');
                var cellAccount = row.querySelector('.cell-account');
                var cellTax = row.querySelector('.cell-tax');
                var cellRemarks = row.querySelector('.cell-remarks');

                // 明細ロード前のスピナー行はスキップ
                if (!cellAmount || !cellCard || !cellItem) return;

                if (enabled) {
                    row.classList.add('editing-row');
                    cellAmount.innerHTML = `<input type="number" class="edit-input text-end" value="${cellAmount.dataset.val}">`;
                    cellCard.innerHTML = `<input type="number" class="edit-input text-end" value="${cellCard.dataset.val}" placeholder="0">`;

                    var currentCode = cellItem.dataset.val;
                    var selectHtml = `<select class="form-select form-select-sm" style="min-width:140px;">`;
                    expenseMasterList.forEach(m => {
                        selectHtml += `<option value="${m.code}" ${String(m.code) === String(currentCode) ? 'selected' : ''}>${m.name}</option>`;
                    });
                    cellItem.innerHTML = selectHtml + '</select>';

                    cellAccount.innerHTML = `<input type="text" class="form-control form-control-sm" value="${cellAccount.dataset.val}" placeholder="例: 旅費交通費" style="min-width:120px;">`;

                    var taxVal = cellTax.dataset.val || '';
                    var taxOptions = ['', '課税仕入（10%）', '課税仕入（軽減税率8%）', '非課税', '免税', '対象外'];
                    var taxSelectHtml = `<select class="form-select form-select-sm" style="min-width:140px;">`;
                    taxOptions.forEach(opt => {
                        taxSelectHtml += `<option value="${opt}" ${opt === taxVal ? 'selected' : ''}>${opt || '-- 選択 --'}</option>`;
                    });
                    cellTax.innerHTML = taxSelectHtml + '</select>';

                    cellRemarks.innerHTML = `<input type="text" class="form-control form-control-sm" value="${cellRemarks.dataset.val || ''}">`;
                } else {
                    row.classList.remove('editing-row');
                }
            });

            if (!enabled) openDetailModal(currentKeiriId);
        }

        // --- 一括保存 ---
        function saveAllChanges() {
            showConfirm('編集内容をすべて保存し、連携元のシートにも反映しますか？', '保存する', function() {
                var updatesList = [];
                document.querySelectorAll('#reportDetailsBody tr').forEach(row => {
                    var inputAmount = row.querySelector('.cell-amount input');
                    if (!inputAmount) return;
                    var newItemCode = row.querySelector('.cell-item select').value;
                    var master = expenseMasterList.find(m => m.code == newItemCode);
                    updatesList.push({
                        detailId: row.dataset.detailId,
                        amount: inputAmount.value,
                        cardAmount: row.querySelector('.cell-card input').value || 0,
                        itemCode: newItemCode,
                        itemName: master ? master.name : '',
                        accountTitle: row.querySelector('.cell-account input') ? row.querySelector('.cell-account input').value : undefined,
                        taxCategory: row.querySelector('.cell-tax select') ? row.querySelector('.cell-tax select').value : undefined,
                        remarks: row.querySelector('.cell-remarks input').value
                    });
                });

                if (updatesList.length === 0) { showToast('変更内容がありません。', true); return; }

                showLoading(true);
                google.script.run
                    .withSuccessHandler(function(res) {
                        showLoading(false);
                        if (res.status === 'success') {
                            showToast(res.message);
                            toggleEditMode(false);
                            loadPendingData();
                        } else {
                            showToast('エラー: ' + res.message, true);
                        }
                    })
                    .updateDetailItems(currentKeiriId, updatesList, currentHeader['システム区分'], currentHeader['元申請ID']);
            });
        }

        // --- 共通アクション ---
        function handleSyncData() {
            showLoading(true);
            google.script.run
                .withSuccessHandler(res => { showLoading(false); showToast(res.message, res.status === 'error'); loadPendingData(); })
                .withFailureHandler(e => { showLoading(false); showToast('同期エラー: ' + e.message, true); })
                .syncDataFromSources();
        }

        function handleBulkProcess() {
            var ids = Array.from(document.querySelectorAll('.pending-checkbox:checked')).map(c => c.value);
            if (ids.length === 0) { showToast('申請を選択してください', true); return; }
            showConfirm(ids.length + '件を支払済にしますか？', '支払済にする', function() {
                showLoading(true);
                google.script.run.withSuccessHandler(res => {
                    showLoading(false);
                    showToast(res.message, res.status === 'error');
                    if (res.status === 'success') removeItemsFromList(ids);
                }).markAsProcessed(ids, USER_NAME);
            });
        }

        function handleBulkReject() {
            var ids = Array.from(document.querySelectorAll('.pending-checkbox:checked')).map(c => c.value);
            if (ids.length !== 1) { showToast('差し戻しは詳細確認のため、1件ずつ行ってください', true); return; }
            openRejectModal(ids[0]);
        }

        function openRejectModal(id) {
            currentKeiriId = id;
            document.getElementById('rejectReason').value = '';
            rejectModal.show();
        }

        function confirmReject() {
            var reason = document.getElementById('rejectReason').value;
            if (!reason) { showToast('差し戻し理由を入力してください', true); return; }
            rejectModal.hide();
            showLoading(true);
            google.script.run.withSuccessHandler(res => {
                showLoading(false);
                showToast(res.message, res.status === 'error');
                if (res.status === 'success') {
                    if (document.getElementById('reportDetailModal').classList.contains('show')) detailModal.hide();
                    removeItemsFromList(currentKeiriId);
                }
            }).markAsRejected(currentKeiriId, reason);
        }

        function handleProcess(id) {
            showConfirm('この申請を支払済にしますか？', '支払済にする', function() {
                detailModal.hide();
                showLoading(true);
                google.script.run.withSuccessHandler(res => {
                    showLoading(false);
                    showToast(res.message, res.status === 'error');
                    if (res.status === 'success') removeItemsFromList(id);
                }).markAsProcessed(id, USER_NAME);
            });
        }

        function exportData(statusFilter) {
            var checkedIds = Array.from(document.querySelectorAll('.pending-checkbox:checked')).map(c => c.value);
            var resolvedStatus = statusFilter || currentStatus;
            var statusLabel = resolvedStatus === '振込済' ? '支払済' : '支払待ち';
            var targetLabel = checkedIds.length > 0 ? checkedIds.length + '件（選択中）' : '全件';
            showConfirm(statusLabel + ' ' + targetLabel + 'をCSV出力しますか？', 'CSV出力', function() {
                showLoading(true);
                google.script.run.withSuccessHandler(res => {
                    showLoading(false);
                    if (res.status === 'success') {
                        var a = document.createElement('a');
                        a.href = 'data:text/csv;charset=utf-8,' + encodeURIComponent(res.csvData);
                        a.download = res.fileName;
                        a.click();
                    } else {
                        showToast(res.message, true);
                    }
                }).exportPendingAsCSV(checkedIds.length > 0 ? checkedIds : null, resolvedStatus);
            });
        }

        function showLoading(show) { document.getElementById('loading-overlay').style.display = show ? 'flex' : 'none'; }
        function formatNumber(num) { return (parseFloat(num) || 0).toLocaleString('ja-JP'); }
        function formatDate(d) { return d ? d.toString().substring(0, 10).replace(/-/g, '/') : ''; }
        function toggleAll(chk) { document.querySelectorAll('.pending-checkbox').forEach(c => c.checked = chk); }
        function escapeHtml(str) {
            if (!str) return '';
            return str.toString().replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
        }
    </script>
</body>
</html>
