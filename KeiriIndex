    <style>
        body { background-color: #f8f9fa; }
        .app-view { display: none; }
        .app-view.active { display: block; }

        /* ローディング */
        #loading-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background-color: rgba(0, 0, 0, 0.6); z-index: 9999;
            display: flex; justify-content: center; align-items: center;
            backdrop-filter: blur(2px);
        }

        /* テーブル関連 */
        .text-break-word { word-break: break-all; }
        .table-hover tbody tr { cursor: pointer; transition: background-color 0.2s; }

        /* 編集モード */
        .editing-row { background-color: #fff8e1 !important; }
        .edit-input { width: 100%; min-width: 70px; padding: 4px; border: 1px solid #ced4da; border-radius: 4px; }
        .cell-amount { font-family: 'Consolas', monospace; }

        /* モーダル内のデザイン調整 */
        .info-label { font-size: 0.75rem; color: #6c757d; margin-bottom: 0; }
        .info-value { font-size: 1.1rem; font-weight: 500; color: #212529; }
        .modal-header { border-bottom: none; padding-bottom: 0; }
        .system-badge { font-size: 0.75rem; padding: 0.25em 0.6em; }

        /* 金額表示 */
        .amount-display { font-family: 'Segoe UI', sans-serif; }

        /* ID非表示用クラス */
        .hidden-id { display: none !important; }
    </style>
</head>
